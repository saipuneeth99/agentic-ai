#!/usr/bin/env python3
"""
Agentic AI Workflow CLI
Professional command-line interface for multi-agent orchestration
"""

import asyncio
import sys
from pathlib import Path
from src.cli.commands import CLIInterface


def check_first_run():
    """Check if this is the first run and setup wizard is needed"""
    session_file = Path(".users/.session")
    return not session_file.exists()


def run_setup_wizard():
    """Run the first-time setup wizard"""
    try:
        from setup_wizard import SetupWizard
        wizard = SetupWizard()
        username = wizard.run()
        print("\n🎉 Setup complete! You're ready to use Agentic AI!\n")
        return True
    except Exception as e:
        print(f"❌ Setup wizard error: {e}")
        print("   You can run setup later with: python3 setup_wizard.py\n")
        return False


def main():
    """Main entry point"""
    
    # Run setup wizard on first run
    if check_first_run():
        print("\n" + "="*70)
        print("Welcome to Agentic AI! Let's get you set up...".center(70))
        print("="*70)
        run_setup_wizard()
    
    # Initialize CLI
    cli = CLIInterface()
    cli.commands["help"].commands = cli.commands
    
    if len(sys.argv) < 2:
        asyncio.run(cli.run("help"))
        return 0
    
    command = sys.argv[1]
    args = sys.argv[2:] if len(sys.argv) > 2 else []
    
    try:
        asyncio.run(cli.run(command, args))
        return 0
    except KeyboardInterrupt:
        print("\n\nInterrupted by user")
        return 130
    except Exception as e:
        print(f"Fatal error: {str(e)}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
